{
  "name": "@aiusage/worker",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ennann/aiusage.git",
    "directory": "packages/worker"
  },
  "type": "module",
  "scripts": {
    "predeploy": "node scripts/build.mjs",
    "deploy": "wrangler deploy",
    "postdeploy": "rm -rf ./public",
    "predev": "node scripts/build.mjs",
    "dev": "wrangler dev",
    "postdev": "rm -rf ./public",
    "build": "node scripts/build.mjs",
    "lint": "tsc --noEmit",
    "types": "wrangler types",
    "test": "node --test scripts/*.test.mjs && vitest run src",
    "db:migrate:local": "wrangler d1 migrations apply aiusage-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply aiusage-db --remote"
  },
  "dependencies": {
    "@aiusage/dashboard": "workspace:*",
    "@aiusage/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  }
}
